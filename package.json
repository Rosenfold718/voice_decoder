{
  "name": "vox-voice-decoder",
  "version": "1.3.1",
  "author": "Rosenfold",
  "description": "Vox — Локальная расшифровка голоса",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "NODE_ENV=production node .next/standalone/server.js",
    "electron:dev": "next dev -p 3000 & sleep 3 && electron .",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.vox.voice-decoder",
    "productName": "Vox",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "out",
        "to": "out"
      },
      {
        "from": "resources/whisper",
        "to": "whisper"
      },
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vox"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.26.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-toast": "^1.2.15",
    "tw-animate-css": "^1.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}